{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Build Doom",
            "command": "g++", 
            "args": [
                "-g",
                "-std=c++17",
                // Includes
                "-I${workspaceFolder}\\include",
                "-IC:\\msys64\\mingw64\\include",  
                "-IC:\\msys64\\ucrt64\\include",     
                // Source files
                "${workspaceFolder}\\src\\glad.c",
                "${workspaceFolder}\\src\\*.cpp",
                // Library directories
                "-L${workspaceFolder}\\lib",
                "-LC:\\msys64\\mingw64\\lib",            
                // Libraries
                "-lglfw3",
                "-lopengl32",
                "-lgdi32",                  
                "-o",
                "${workspaceFolder}\\app.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}